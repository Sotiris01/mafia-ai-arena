{
  "probability_per_night": 0.15,
  "max_activations_per_game": 3,
  "min_night": 3,
  "expected_town_ratio_formula": "initial_town / initial_total",
  "score_direction": {
    "positive_score": "Town overpowers — Mafia receives boost",
    "negative_score": "Mafia overpowers — Town receives boost",
    "logic": "Use Math.abs(score) for stage lookup; sign(score) determines boosted faction"
  },
  "thresholds": {
    "stage_0": {
      "min": -0.05,
      "max": 0.05,
      "label": "Balanced"
    },
    "stage_1": {
      "min": 0.05,
      "max": 0.15,
      "label": "Slight Imbalance"
    },
    "stage_2": {
      "min": 0.15,
      "max": 1,
      "label": "Major Imbalance"
    }
  },
  "buffs": {
    "stage_0": {
      "type": "none",
      "description": "No effect — game is balanced",
      "extra_actions": 0
    },
    "stage_1": {
      "type": "info",
      "description": "Info roles of the losing faction get +1 extra action",
      "extra_actions": 1,
      "eligible_roles": {
        "town": [
          "Sheriff",
          "Lookout",
          "Tracker"
        ],
        "mafia": [
          "Consigliere",
          "Framer",
          "Silencer"
        ]
      }
    },
    "stage_2": {
      "type": "full",
      "description": "ALL roles of the losing faction get +1 extra action",
      "extra_actions": 1,
      "includes_mafia_kill": true,
      "includes_doctor_protect": true,
      "includes_passive_hints": true
    }
  },
  "excluded_from_boost": [
    "Bodyguard",
    "Zombie",
    "Survivor",
    "Lovers"
  ],
  "announcement_templates": {
    "stage_1": "The Full Moon rises... the {faction} feels a surge of insight.",
    "stage_2": "The Full Moon blazes! The {faction} is empowered with extraordinary strength!"
  }
}
